import java.util.Scanner;
public class eligibletovotefunctions {
    public static void person(int age){
        if(age>=18){
            System.out.println("person eligible to vote");
        }else{
            System.out.println("person not eligible to vote he needs "+(18-age)+" more years to vote");
        }
    }
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.println("enter the age:");
        int age=sc.nextInt();
        person(age);
        sc.close();
    }
}
