import java.util.Scanner;
public class modulodivisiontwonumbersfunctions {
    public static void moddiv(int a,int b){
        if(b==0){
            System.out.println("error! modulo division not possible");
        }
        else{
            int c=a/b;
            System.out.println("modulo division two numbers ="+c);
        }
    }
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.print("enter the first number:");
        int n1=sc.nextInt();
        System.out.print("enter the second number:");
        int n2=sc.nextInt();
        moddiv(n1, n2);
        sc.close();
    }
}
